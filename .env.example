# Copia este archivo a .env.local para desarrollo local (nunca subas .env.local a GitHub).
# En producción, estas mismas variables se configuran en Vercel > Project > Settings > Environment Variables.

# API key de Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Contraseña del panel admin (elige una tuya, no la del ejemplo del código viejo)
ADMIN_PASSWORD=

# Opcional pero recomendado: protege /api/actualizar-precios para que solo
# el cron de Vercel pueda dispararlo. Genera cualquier string largo random.
CRON_SECRET=

# Estas dos las inyecta automáticamente Vercel cuando instalas la integración
# de Upstash Redis desde el Marketplace (Storage > Create Database > Upstash).
# No hace falta que las escribas a mano salvo que estés probando en local.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
